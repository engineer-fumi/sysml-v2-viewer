{
  "name": "sysml-v2-viewer",
  "displayName": "SysML v2 Viewer",
  "description": "SysML v2 (.sysml / .kerml) のオーサリングと可視化: シンタックスハイライト・補完・診断・アウトライン・定義ジャンプ・インターコネクション図",
  "version": "0.5.0",
  "publisher": "engineer-fumi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/engineer-fumi/sysml-v2-viewer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "sysml",
    "sysml-v2",
    "kerml",
    "mbse",
    "modeling"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sysml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": [
          "SysML v2",
          "sysml"
        ],
        "extensions": [
          ".sysml",
          ".kerml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "sysml.openDiagram",
        "title": "SysML: ダイアグラムを開く",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "sysml.openDiagramAs",
        "title": "SysML: 図の種類を選んで開く",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "sysml.openDiagram",
          "when": "editorLangId == sysml",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "sysml.openDiagram"
        },
        {
          "command": "sysml.openDiagramAs"
        }
      ]
    },
    "configuration": {
      "title": "SysML v2 Viewer",
      "properties": {
        "sysml.validation.unresolvedReferences": {
          "type": "string",
          "enum": ["error", "warning", "information", "off"],
          "default": "warning",
          "description": "未解決の参照 (型・特化・接続先など) の診断レベル"
        },
        "sysml.validation.duplicateNames": {
          "type": "string",
          "enum": ["error", "warning", "information", "off"],
          "default": "error",
          "description": "同一スコープ内の重複名の診断レベル"
        },
        "sysml.validation.typeConformance": {
          "type": "string",
          "enum": ["error", "warning", "information", "off"],
          "default": "warning",
          "description": "型付け・特化の種類整合 (part は part def で型付け 等) の診断レベル"
        },
        "sysml.validation.shadowing": {
          "type": "string",
          "enum": ["error", "warning", "information", "off"],
          "default": "warning",
          "description": "継承メンバーを同名宣言で隠している場合 (:>> による再定義を推奨) の診断レベル"
        },
        "sysml.validation.importVisibility": {
          "type": "string",
          "enum": ["error", "warning", "information", "off"],
          "default": "warning",
          "description": "import の可視性 (public / private) が明示されていない場合の診断レベル"
        }
      }
    }
  },
  "scripts": {
    "check": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "build": "npm run check && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test:core": "esbuild test/core.ts --bundle --platform=node --outfile=dist/core-test.cjs --log-level=error && node dist/core-test.cjs",
    "test:vscode": "node test/runTest.mjs",
    "package": "npm run build && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.3"
  }
}
